<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Temperature (0.0 - 2.0)" android:textSize="16sp"/>
        <SeekBar android:id="@+id/slider_temp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/value_temp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Top-P (0.0 - 1.0)" android:textSize="16sp"
            android:layout_marginTop="24dp"/>
        <SeekBar android:id="@+id/slider_topp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/value_topp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Max Tokens (1 - 1024)" android:textSize="16sp"
            android:layout_marginTop="24dp"/>
        <SeekBar android:id="@+id/slider_max"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/value_max" android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>
